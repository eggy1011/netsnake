# Gemini Developer API key for AI answer evaluation (free tier works).
# Get one at https://aistudio.google.com/apikey
# NEVER expose this in frontend code — it is read only by server/index.mjs.
GEMINI_API_KEY=

# Free-tier text model. Default verified against the official model list
# (https://ai.google.dev/gemini-api/docs/models) on 2026-07-07.
# Check that page if the free-tier lineup changes.
GEMINI_MODEL=gemini-3.5-flash

# Evaluation server port (vite dev proxies /api here).
PORT=8787
